{
  "PULM_COUGH_V1": {
    "cc_id": "cough",
    "cluster_prefix": "C",
    "activate": [
      {
        "dx": "pneumonia",
        "when": "ALL(answers.Q_C_FEVER == 'yes', answers.Q_C_SOB == 'yes')",
        "points": 5,
        "label": "Pneumonia pattern (fever + SOB)"
      },
      {
        "dx": "asthma_exacerbation",
        "when": "ALL(answers.Q_C_SOB == 'yes', answers.Q_C_FEVER != 'yes')",
        "points": 4,
        "label": "Asthma exacerbation (SOB without fever)"
      },
      {
        "dx": "viral_uri",
        "when": "ALL(answers.Q_C_FEVER != 'yes', answers.Q_C_SOB != 'yes')",
        "points": 3,
        "label": "Viral URI (no fever, no SOB)"
      }
    ]
  },
  "ENT_SINUS_V1": {
    "cc_id": "sinus_pressure",
    "cluster_prefix": "SP",
    "activate": [
      {
        "dx": "acute_bacterial_sinusitis",
        "when": "ANY(answers.Q_SP_DUR >= 10, ALL(answers.Q_SP_FEVER == 'yes', answers.Q_SP_PAIN == 'yes'))",
        "points": 5,
        "label": "Acute bacterial sinusitis (prolonged or fever+pain)"
      },
      {
        "dx": "allergic_rhinitis",
        "when": "ALL(answers.Q_SP_FEVER != 'yes', answers.Q_SP_PAIN != 'yes')",
        "points": 3,
        "label": "Allergic rhinitis (no fever, no pain)"
      },
      {
        "dx": "viral_rhinosinusitis",
        "when": "ALL(answers.Q_SP_DUR < 10, answers.Q_SP_FEVER != 'yes')",
        "points": 3,
        "label": "Viral rhinosinusitis (short duration, no fever)"
      }
    ]
  },
  "CARD_CP_V1": {
    "cc_id": "chest_pain",
    "cluster_prefix": "CP",
    "activate": [
      {
        "dx": "mi",
        "when": "ANY(answers.Q_CP_RADIATES == 'yes', answers.Q_CP_DIAPHORESIS == 'yes', answers.Q_CP_EXERTIONAL == 'yes')",
        "points": 6,
        "label": "MI pattern (radiation/diaphoresis/exertional)"
      },
      {
        "dx": "pe",
        "when": "ALL(answers.Q_CP_SOB == 'yes', answers.Q_CP_PLEURITIC == 'yes')",
        "points": 6,
        "label": "PE pattern (SOB + pleuritic)"
      },
      {
        "dx": "pneumothorax",
        "when": "ALL(answers.Q_CP_SOB == 'yes', answers.Q_CP_PLEURITIC == 'yes', answers.Q_CP_REPRODUCIBLE != 'yes')",
        "points": 5,
        "label": "Pneumothorax pattern (SOB + pleuritic, not reproducible)"
      }
    ]
  },
  "ENT_SINUS_V2": {
    "cc_id": "sinus_pressure",
    "cluster_prefix": "SP",
    "activate": [
      {
        "dx": "acute_bacterial_sinusitis",
        "when": "false",
        "points": 6,
        "label": "Acute Bacterial Sinusitis (primary - auto-generated)"
      },
      {
        "dx": "allergic_rhinitis",
        "when": "false",
        "points": 4,
        "label": "Allergic Rhinitis (secondary - auto-generated)"
      },
      {
        "dx": "viral_rhinosinusitis",
        "when": "true",
        "points": 3,
        "label": "Viral Rhinosinusitis (benign - auto-generated)"
      }
    ]
  },
  "PULM_COUGH_V2": {
    "cc_id": "cough",
    "cluster_prefix": "C",
    "activate": [
      {
        "dx": "pneumonia",
        "when": "false",
        "points": 6,
        "label": "Pneumonia (primary - auto-generated)"
      },
      {
        "dx": "asthma_exacerbation",
        "when": "false",
        "points": 4,
        "label": "Asthma Exacerbation (secondary - auto-generated)"
      },
      {
        "dx": "viral_uri",
        "when": "true",
        "points": 3,
        "label": "Viral Uri (benign - auto-generated)"
      }
    ]
  },
  "CARD_CP_V2": {
    "cc_id": "chest_pain",
    "cluster_prefix": "CP",
    "activate": [
      {
        "dx": "mi",
        "when": "false",
        "points": 6,
        "label": "Mi (primary - auto-generated)"
      },
      {
        "dx": "pe",
        "when": "false",
        "points": 6,
        "label": "Pe (primary - auto-generated)"
      },
      {
        "dx": "pneumothorax",
        "when": "false",
        "points": 6,
        "label": "Pneumothorax (primary - auto-generated)"
      }
    ]
  }
}
