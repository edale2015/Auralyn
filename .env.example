# =============================================================================
# ENT Flu Slice / Auralyn — Environment Variables
# Copy this file to .env and fill in values
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/auralyn
REDIS_URL=redis://localhost:6379
DB_PATH=./data.sqlite
STORAGE_DRIVER=memory

# ── Authentication ───────────────────────────────────────────────────────────
APP_JWT_SECRET=your_jwt_secret_here
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-different-long-random-secret
MD_PASSWORD=replace-with-a-strong-physician-password
CLINICIAN_PASSWORD=replace-with-a-strong-clinician-password
ADMIN_TOKEN=
SESSION_TTL_HOURS=24
SESSION_COOKIE_NAME=session
COOKIE_SECURE=false

# ── OpenAI / AI Integration ─────────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Google Sheets (Pack Repository) ──────────────────────────────────────────
PACK_REPO_DRIVER=memory
PACKS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_PROJECT=
SHEETS_SPREADSHEET_ID=
SHEETS_SPREADSHEET_ID_STAGING=

# ── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# ── Twilio / WhatsApp ────────────────────────────────────────────────────────
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
ENABLE_WHATSAPP_INTAKE=false
USE_ORCHESTRATOR_WHATSAPP=false
STAFF_WHATSAPP_NUMBERS=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ENABLE_TELEGRAM_INTAKE=false
STAFF_TELEGRAM_IDS=

# ── EHR Integration ─────────────────────────────────────────────────────────
EHR_VENDOR=
EHR_ENDPOINT=
EHR_FHIR_BASE_URL=
EHR_API_KEY=
EHR_CLIENT_ID=
EHR_CLIENT_SECRET=
EHR_REDIRECT_URI=
EHR_SCOPES=
EHR_ALLOW_WRITES=false
EHR_DEAD_LETTER_TTL_HOURS=72
EHR_RETRY_MAX=3

# ── Translation ──────────────────────────────────────────────────────────────
DEEPL_API_KEY=

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_TEST_ROUTES=false
ENABLE_TEST_CONSOLE=false
ENABLE_COUNCIL=false
ENABLE_MESSAGE_RETENTION=false
SHADOW_MODE_ENABLED=false
STAGING=false
AUTO_PROMOTE_TO_STAGING=false
ALLOW_PROVIDER_KEY_FALLBACK=false
REVIEW_AUTH_MODE=cookie

# ── Testing & Reports ───────────────────────────────────────────────────────
TEST_EXEC_TOKEN=
TEST_SHEET_ENV=
TEST_RUNS_SHEET_TAB=
TESTS_PER_FLOW=5
REPORT_DAYS=30
REPORT_OUTPUT_DIR=./reports
SCORECARD_DAYS=30
SUMMARY_DIR=./reports

# ── Operational ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOADS_MODE=local
RETENTION_TTL_DAYS=90
ROUTER_AUDIT_HISTORY_MAX=100
GIT_COMMIT_SHA=

# ── Governance Gates ────────────────────────────────────────────────────────
GATE_FAIL_ON_REGRESSION=false
GATE_MAX_FAIL_INCREASE=10
GATE_MAX_FAILRATE_INCREASE=5
GATE_MAX_AVGSEV_INCREASE=1

# ── Sensory Cortex / Devices / Robotics ─────────────────────────────────────
DEVICE_API=http://device-gateway.local
ROBOT_API_URL=http://robot.local
WEBRTC_WS=wss://yourdomain/ws/webrtc
VOICE_PROVIDER=twilio
VISION_MODEL=gpt-4o

# ── Fly.io / AWS Deploy ──────────────────────────────────────────────────────
FLY_API_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── EHR — Athena Health ──────────────────────────────────────────────────────
ATHENA_API_BASE=
ATHENA_PRACTICE_ID=
ATHENA_TOKEN=
ATHENA_DEFAULT_DEPARTMENT_ID=1

# ── EHR — Epic / SMART ───────────────────────────────────────────────────────
FHIR_BASE=
SMART_CLIENT_ID=
SMART_REDIRECT=
EPIC_TOKEN=

# ── EHR — ECW ────────────────────────────────────────────────────────────────
ECW_API=
ECW_TOKEN=
